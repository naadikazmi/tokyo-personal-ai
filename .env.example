# Frontend-safe values. These may be included in the browser app.
# Leave blank for local/demo mode.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ENABLE_GOOGLE_OAUTH=false
EXPO_PUBLIC_API_BASE_URL=http://localhost:8083

# Server-only values. Do not prefix secrets with EXPO_PUBLIC_.
API_PORT=8083
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
RESEARCH_PROVIDER=
RESEARCH_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
